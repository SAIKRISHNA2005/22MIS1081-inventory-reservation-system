# ─── PostgreSQL (Supabase or Neon) ───────────────────────────────────────────
#
# DATABASE_URL  → pooled connection for the app (Vercel serverless)
# DIRECT_URL    → direct connection for Prisma migrations at build time
#
# Supabase (recommended):
#   DATABASE_URL = Transaction pooler, port 6543, append:
#     ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = Session pooler URI, port 5432 on *.pooler.supabase.com
#                  (Supabase → Connect → Session pooler — use for migrate/seed)
#
# Neon:
#   DATABASE_URL = pooled host (ends with -pooler), append ?sslmode=require
#   DIRECT_URL   = non-pooled host
#
# Do NOT swap DATABASE_URL and DIRECT_URL.
# Do NOT use port 5432 for DATABASE_URL on Vercel.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Upstash Redis (idempotency — optional, failures are ignored) ─────────────
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# Vercel Cron — protects /api/cron/* in production
CRON_SECRET="your-secret-here"
